SUPABASE_URL=<your-supabase-url>
SUPABASE_KEY=<your-supabase-anon-key>
SUPABASE_MEAL_IMAGES_BUCKET=meal-images
VITE_CONTACT_MAIL=<your-contact-email>

# Production/Demo Settings
NUXT_PUBLIC_SIGNUP_DISABLED=false
NUXT_PUBLIC_DEMO_EMAIL=demo@mealsnap.app
NUXT_PUBLIC_DEMO_PASSWORD=demo123456

# Note: TensorFlow.js works locally without any API keys!

# The public URL of your deployed app.
# Used by the CSRF middleware to validate the Origin header on mutation API requests.
# In development this defaults to http://localhost:3000.
# In production set this to your real domain (e.g. https://mealsnap.app).
NUXT_PUBLIC_APP_URL=http://localhost:3000